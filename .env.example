# API Configuration (any OpenAI-compatible endpoint that supports Gemini image models)
GEMINI_API_KEY=your_api_key_here
GEMINI_API_BASE=https://openrouter.ai/api/v1

# Optional: override default models
# GEMINI_MODEL=gemini-3-pro-image-preview
# GEMINI_FLASH_MODEL=gemini-3.1-flash-image-preview

# Optional: default output directory
# OUTPUT_DIR=/path/to/output/directory
